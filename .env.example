# BATON — Environment Variables

# Server
VMC_PORT=4200
# PORT=4200 is also supported for hosting environments
# BATON_HOST defaults to 127.0.0.1. For private tailnet/LAN hosting, bind to a specific private IP.
# Do not use 0.0.0.0 unless you have added appropriate network and write-auth controls.
# BATON_HOST=127.0.0.1
# Required for /api routes when BATON_HOST/HOST binds outside localhost; optional on localhost.
BATON_API_TOKEN=

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_WORKER_TOKEN=your-github-personal-access-token

# Redis (optional for local Flow development)
REDIS_URL=redis://127.0.0.1:6379

# Shared Requests (optional, token-protected)
SHARED_REQUESTS_TOKEN=change-me-local-token
# BATON public callback base for agents. For remote agents, set this to a tunnel/public URL.
BATON_PUBLIC_BASE_URL=http://127.0.0.1:4200

# Optional callback auth used by /api/runs/:id/ack and /api/runs/:id/status.
BATON_CALLBACK_TOKEN=change-me

# Spectre dispatch v1
SPECTRE_DISPATCH_TRANSPORT=webhook
SPECTRE_WEBHOOK_URL=http://127.0.0.1:4300/baton/dispatch
SPECTRE_DISPATCH_TOKEN=change-me
