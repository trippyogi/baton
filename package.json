{
  "name": "baton",
  "version": "1.0.0",
  "description": "BATON Flow Ops — Next-Touch Engine",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "check:js": "find server public/js -name '*.js' -print0 | xargs -0 -n1 node --check",
    "smoke": "node scripts/smoke-flow.js",
    "audit": "npm audit --audit-level=moderate --omit=dev",
    "test": "npm run check:js && npm run smoke"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "ioredis": "^5.11.1"
  }
}
