{
  "name": "baton",
  "version": "0.1.0",
  "description": "BATON Flow Ops \u2014 Next-Touch Engine",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "check:js": "node scripts/check-js.js",
    "smoke": "node scripts/smoke-flow.js",
    "audit": "npm audit --audit-level=moderate --omit=dev",
    "audit:private": "node scripts/audit-private-data.js",
    "import:local": "node scripts/import-local-profile.js",
    "export:redacted": "node scripts/export-redacted.js",
    "test": "npm run check:js && npm run smoke",
    "preinstall": "node -e \"const major=process.versions.node.split('.')[0]; if(major !== '20'){ console.error('BATON requires Node 20. Run: nvm use'); process.exit(1); }\"",
    "fake:spectre": "node scripts/fake-spectre.js",
    "smoke:dispatch": "node scripts/smoke-dispatch-spectre.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "ioredis": "^5.11.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trippyogi/baton.git"
  },
  "bugs": {
    "url": "https://github.com/trippyogi/baton/issues"
  },
  "homepage": "https://github.com/trippyogi/baton#readme",
  "engines": {
    "node": ">=20 <21"
  }
}
